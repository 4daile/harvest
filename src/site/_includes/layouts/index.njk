---
permalink: "notes/{{ page.fileSlug | slugify }}/"
---
<!DOCTYPE html>
<html lang="{{ meta.mainLanguage }}">
  <head>
    <title>{% if title %}{{ title }}{% else %}{{ page.fileSlug }}{% endif %}</title>
    {%include "components/pageheader.njk"%}
    {% for imp in dynamics.common.head %}
      {% include imp %}
    {% endfor %}
    {% for imp in dynamics.notes.head %}
      {% include imp %}
    {% endfor %}
  </head>
  <body class="theme-{{meta.baseTheme}} markdown-preview-view markdown-rendered markdown-preview-section {% if settings.dgShowFileTree !== true %}no-filetree{% endif %} {% if settings.dgHomeLink === true and settings.dgShowFileTree !== true %}has-navbar{% endif %} {{meta.bodyClasses}}">
    {%include "components/notegrowthhistory.njk"%}

    {% if settings.dgShowFileTree !== true %}
      {%include "components/navbar.njk"%}
    {%else%}
      {%include "components/filetree.njk"%}
    {% endif %}
    {% if settings.dgEnableSearch === true %}
      {%include "components/searchContainer.njk"%}
    {% endif %}

    <main class="content cm-s-obsidian print {{contentClasses}}">
      <header>
        {% if settings.dgShowInlineTitle === true %}
          <h1 data-note-icon="{% if noteIcon %}{{noteIcon}}{% else %}{{meta.noteIconsSettings.default}}{% endif %}">{% if title %}{{ title }}{% else %}{{ page.fileSlug }}{% endif %}</h1>
        {% endif %}
      </header>

      {{ content | hideDataview | taggify | link | safe }}

      {# ===== DERNIÈRES PUBLICATIONS - CARTES ===== #}
      <section class="recent-cards-section">
        <h2 class="recent-cards-title">dernières publications</h2>
        <div class="recent-cards-grid">

          {%- set cardColors = ["card--yellow", "card--orange", "card--blue", "card--green", "card--pink"] -%}
          {%- set cardCount = 0 -%}

          {%- for note in collections.all | reverse -%}
            {%- if note.data["dg-publish"] and note.data.tags and "gardenEntry" not in note.data.tags -%}
              {%- if cardCount < 6 -%}

                {%- set colorClass = cardColors[cardCount % 5] -%}

                {%- set categoryLabel = "" -%}
                {%- if note.data.tags -%}
                  {%- if "nouvelle" in note.data.tags -%}{%- set categoryLabel = "nouvelle" -%}
                  {%- elif "article" in note.data.tags -%}{%- set categoryLabel = "article" -%}
                  {%- elif "blog" in note.data.tags -%}{%- set categoryLabel = "blog" -%}
                  {%- endif -%}
                {%- endif -%}

                <a href="{{ note.url }}" class="note-card {{ colorClass }}">
                  <div class="note-card-inner">
                    {% if categoryLabel %}
                      <span class="note-card-tag">{{ categoryLabel }}</span>
                    {% endif %}
                    <h3 class="note-card-title">
                      {% if note.data.title %}{{ note.data.title }}{% else %}{{ note.fileSlug }}{% endif %}
                    </h3>
                    {% if note.data.description %}
                      <p class="note-card-excerpt">{{ note.data.description }}</p>
                    {% endif %}
                    <span class="note-card-arrow">→</span>
                  </div>
                </a>

                {%- set cardCount = cardCount + 1 -%}
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}

        </div>
      </section>

      {% for imp in dynamics.common.afterContent %}
        {% include imp %}
      {% endfor %}
      {% for imp in dynamics.notes.afterContent %}
        {% include imp %}
      {% endfor %}
    </main>

    {% if settings.dgShowBacklinks === true or settings.dgShowLocalGraph === true or settings.dgShowToc === true%}
      {%include "components/sidebar.njk"%}
    {% endif %}
    {% include "components/references.njk" %}
    {% include "components/timestamps.njk" %}
    {% for imp in dynamics.common.footer %}
      {% include imp %}
    {% endfor %}
    {% for imp in dynamics.notes.footer %}
      {% include imp %}
    {% endfor %}
    {%include "components/lucideIcons.njk"%}
  </body>
</html>
